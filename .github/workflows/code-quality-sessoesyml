name: Code Quality Analysis for Backend Module

on:
  workflow_call:

jobs:
  code-quality-sessoes:
    name: Lint do módulo ms-sessoes
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v6

      - name: Set up JDK 17
        uses: actions/setup-java@v5
        with:
          java-version: '17'
          distribution: 'temurin'
          cache: 'maven'
      
      - name: Run Checkstyle
        run: mvn -B -f ms-sessoes/pom.xml spotless:apply

      - name: Compile Backend Module
        run: mvn -B -f ms-sessoes/pom.xml clean package -DskipTests

      - name: Run Checkstyle
        run: mvn -B -f ms-sessoes/pom.xml checkstyle:check

      - name: Generate Checkstyle report
        run: mvn -B -f ms-sessoes/pom.xml checkstyle:checkstyle

      - name: Run PMD check
        run: mvn -B -f ms-sessoes/pom.xml pmd:check

      - name: generate PMD report
        run: mvn -B -f ms-sessoes/pom.xml pmd:pmd
      
      - name: Run spotbugs check
        run: mvn -B -f ms-sessoes/pom.xml spotbugs:check

      - name: Generate SpotBugs report
        run: mvn -B -f ms-sessoes/pom.xml spotbugs:spotbugs
  