@startuml context_diagram

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title Votacao - Diagrama de Contexto

Person(user, "Usuario", "Usuario final que participa e consulta votacoes")

System_Ext(frontend, "Frontend", "Aplicacao web consumindo a API")

System(system, "Plataforma de Votacao", "Microsservicos para associados, pautas e sessoes")

System_Ext(sql, "Bancos SQL", "Persistencia dos microsservicos de dominio")
System_Ext(eureka, "Service Discovery", "Registro e descoberta de servicos")

Rel(user, frontend, "Usa")
Rel(frontend, system, "Consome", "HTTPS/JSON")
Rel(system, sql, "Le e grava")
Rel(system, eureka, "Registra e descobre servicos")

@enduml